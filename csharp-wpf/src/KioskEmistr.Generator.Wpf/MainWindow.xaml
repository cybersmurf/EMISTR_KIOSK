<Window x:Class="KioskEmistr.Generator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EMISTR | Kiosk Generator"
        Width="550" Height="580"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

  <DockPanel>

    <!-- Header -->
    <Border DockPanel.Dock="Top" Background="White" Height="100"
            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
      <Grid Margin="30,0">
        <Image Source="pack://application:,,,/agerit_logo.png"
               Height="50" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <Image Source="pack://application:,,,/emistr_logo.png"
               Height="50" HorizontalAlignment="Right" VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Tlacitko dole -->
    <Button DockPanel.Dock="Bottom"
            x:Name="BtnGenerate" Content="VYGENEROVAT EXE"
            Click="Generate_Click"
            Height="55" Margin="40,0,40,30"
            Background="#2D3748" Foreground="White"
            FontSize="16" FontWeight="Bold"
            BorderThickness="0" Cursor="Hand"/>

    <!-- Status -->
    <TextBlock DockPanel.Dock="Bottom"
               x:Name="TxtStatus" Text=""
               Foreground="#718096" FontSize="12"
               HorizontalAlignment="Center"
               Margin="0,0,0,8"/>

    <!-- Formular -->
    <StackPanel Margin="40,24,40,0">

      <TextBlock Text="Nazev Aplikace" Foreground="#4A5568" FontSize="13" Margin="0,0,0,4"/>
      <TextBox x:Name="TxtAppName"
               Height="38" Padding="10,8" FontSize="14"
               BorderBrush="#CBD5E0" BorderThickness="1" Background="White"/>

      <TextBlock Text="Cilova URL adresa" Foreground="#4A5568" FontSize="13" Margin="0,16,0,4"/>
      <TextBox x:Name="TxtUrl"
               Height="38" Padding="10,8" FontSize="14"
               BorderBrush="#CBD5E0" BorderThickness="1" Background="White"/>

      <!-- RS232 sekce -->
      <Border Margin="0,20,0,0" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="0,16,0,0">
        <StackPanel>
          <TextBlock Text="RS232 ctecky (volitelne)" Foreground="#718096" FontSize="12"
                     FontWeight="SemiBold" Margin="0,0,0,12"/>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="12"/>
              <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition/>
              <RowDefinition Height="6"/>
              <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Barcode -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctecka carovych kodu — COM port"
                       Foreground="#4A5568" FontSize="12" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Baud rate"
                       Foreground="#4A5568" FontSize="12" Margin="0,0,0,4"/>
            <TextBox Grid.Row="0" Grid.Column="0"
                     x:Name="TxtBarcodePort" Height="34" Padding="8,6" FontSize="13"
                     BorderBrush="#CBD5E0" BorderThickness="1" Background="White"
                     ToolTip="Napr. COM3 — nechte prazdne pro deaktivaci"/>
            <TextBox Grid.Row="0" Grid.Column="2"
                     x:Name="TxtBarcodeBaud" Height="34" Padding="8,6" FontSize="13"
                     Text="9600" BorderBrush="#CBD5E0" BorderThickness="1" Background="White"/>

            <!-- RFID -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="RFID ctecka cipů — COM port"
                       Foreground="#4A5568" FontSize="12" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Baud rate"
                       Foreground="#4A5568" FontSize="12" Margin="0,0,0,4"/>
            <TextBox Grid.Row="2" Grid.Column="0"
                     x:Name="TxtRfidPort" Height="34" Padding="8,6" FontSize="13"
                     BorderBrush="#CBD5E0" BorderThickness="1" Background="White"
                     ToolTip="Napr. COM4 — nechte prazdne pro deaktivaci"/>
            <TextBox Grid.Row="2" Grid.Column="2"
                     x:Name="TxtRfidBaud" Height="34" Padding="8,6" FontSize="13"
                     Text="9600" BorderBrush="#CBD5E0" BorderThickness="1" Background="White"/>
          </Grid>
        </StackPanel>
      </Border>

    </StackPanel>

  </DockPanel>
</Window>
